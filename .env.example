# Application
APP_NAME="Personal Website API"
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=changeme
DB_NAME=personal_website
DB_ECHO=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# CORS (use ["*"] to allow any origin; credentials are disabled automatically in that case)
CORS_ORIGINS=["*"]

# Auth / JWT
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Cloudflare R2 (S3-compatible object storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Public base URL (custom domain or r2.dev). Leave empty if objects are private.
R2_PUBLIC_BASE_URL=
